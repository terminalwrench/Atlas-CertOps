{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/demo/:path*", "destination": "/index.html" },
    { "source": "/app/:path*", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/onboarding", "destination": "/index.html" },
    { "source": "/docs", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/security", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/demo/:path*", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/app/:path*", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/login", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/signup", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/onboarding", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/docs", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/privacy", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/terms", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/security", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/contact", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/(.*)", "headers": [
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
      { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
    ] }
  ]
}
